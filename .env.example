# Copy this file to .env and replace the example paths.

# Gradio / nnU-Net application
nnUNet_raw=/path/to/nnUNet_raw
nnUNet_preprocessed=/path/to/nnUNet_preprocessed
nnUNet_results=/path/to/nnUNet_results
OASIS_RF_MODEL=/path/to/oasis_rf_model.joblib
OASIS_RUNTIME_DIR=/path/to/runtime
OASIS_NNUNET_DATASET_ID=1
OASIS_NNUNET_CONFIGURATION=3d_fullres
OASIS_NNUNET_FOLD=0
OASIS_NNUNET_CHECKPOINT=checkpoint_best.pth
GRADIO_SHARE=false

# RAG explanation demo
OPENAI_API_KEY=replace_me
